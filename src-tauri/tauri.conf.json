{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "EasyCursorSwap",
  "version": "0.1.0",
  "identifier": "dev.easycursorswap.app",
  "build": {
    "frontendDist": "../.output/public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run generate"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "EasyCursorSwap",
        "label": "main",
        "width": 1280,
        "height": 820,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost data: blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis"],
    "publisher": "EasyCursorSwap",
    "homepage": "https://github.com/nishiuriraku/easy-cursor-swap",
    "category": "Utility",
    "shortDescription": "Win11 cursor manager",
    "longDescription": "Next-generation Windows mouse cursor manager with Ed25519 signed theme distribution.",
    "fileAssociations": [
      {
        "ext": ["cursorpack"],
        "name": "EasyCursorSwap Theme Pack",
        "description": "EasyCursorSwap Theme Pack",
        "role": "Editor",
        "mimeType": "application/x-cursorpack"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "wix": {
        "language": {
          "en-US": {},
          "ja-JP": {
            "localePath": "wix/ja-JP.wxl"
          }
        },
        "fragmentPaths": [],
        "componentRefs": [],
        "featureRefs": [],
        "mergeRefs": []
      },
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["Japanese", "English"],
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/nishiuriraku/easy-cursor-swap/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdFOTEzM0YxRjc1OTlDMQpSV1RCbVhVZlB4UHBCd1o5enQvdzdvQ0JzMGV1K3RrS2lCYk1nZTMvOUV1ZGlTbHNnTkhxZVg3dQo="
    }
  }
}
