{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CursorForge",
  "version": "0.1.0",
  "identifier": "dev.cursorforge.app",
  "build": {
    "frontendDist": "../.output/public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run generate"
  },
  "app": {
    "windows": [
      {
        "title": "CursorForge",
        "label": "main",
        "width": 1100,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self'"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "CursorForge"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "CursorForge",
    "homepage": "https://github.com/cursorforge/cursor-forge",
    "category": "Utility",
    "shortDescription": "Win11 cursor manager",
    "longDescription": "Next-generation Windows mouse cursor manager with Ed25519 signed theme distribution.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["ja-JP", "en-US"],
        "fragmentPaths": [],
        "componentRefs": [],
        "featureRefs": [],
        "mergeRefs": []
      },
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["Japanese", "English"],
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/cursorforge/cursor-forge/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "TAURI_SIGNING_PUBLIC_KEY_PLACEHOLDER"
    }
  }
}
